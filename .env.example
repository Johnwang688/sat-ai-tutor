# App / Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# AI / Tutor
OPENAI_API_KEY=
# Optional; omit both to use default gpt-5.4-nano (OPENAI_MODEL_DEFAULT in apps/web/src/server/env.ts)
OPENAI_MODEL_TUTOR=gpt-5.4-nano
OPENAI_MODEL_GENERATION=gpt-5.4-nano

# Desmos (set DESMOS_API_KEY in deployment; apps/web/next.config.ts exposes it to the client bundle)
DESMOS_API_KEY=
# Optional override if you need a separate public key locally
NEXT_PUBLIC_DESMOS_API_KEY=

# Observability
NEXT_PUBLIC_POSTHOG_KEY=
SENTRY_DSN=

# Billing / Email later
STRIPE_SECRET_KEY=
RESEND_API_KEY=
